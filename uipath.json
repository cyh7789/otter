{
  "$schema": "https://cloud.uipath.com/draft/2024-12/uipath",
  "runtimeOptions": {
    "isConversational": false
  },
  "packOptions": {
    "fileExtensionsIncluded": [".py", ".json", ".md", ".lock", ".toml"],
    "filesIncluded": [
      "main.py",
      "graph.py",
      "schemas.py",
      "uipath.json",
      "bindings.json",
      "entry-points.json",
      "langgraph.json",
      "project.uiproj",
      "pyproject.toml",
      "uv.lock",
      "README.md"
    ],
    "filesExcluded": [".env", ".env.example", "HANDOFF.md"],
    "directoriesExcluded": [
      ".venv",
      ".uv-cache",
      "__pycache__",
      ".pytest_cache",
      "__uipath"
    ],
    "includeUvLock": true
  },
  "functions": {},
  "agents": {
    "otter": "./graph.py:graph"
  }
}
